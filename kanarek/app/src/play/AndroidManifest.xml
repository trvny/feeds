<?xml version="1.0" encoding="utf-8"?>
<!-- play-flavor overlay: registers the Cast framework's OptionsProvider. The foss flavor has
     no Play Services and therefore no such entry. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <meta-data
            android:name="com.google.android.gms.cast.framework.OPTIONS_PROVIDER_CLASS_NAME"
            android:value="com.kanarek.cast.CastOptionsProvider" />
    </application>
</manifest>
