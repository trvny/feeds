{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kanarek",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "observability": { "enabled": true },
  "vars": {
    "DEFAULT_FEEDS": "https://news.google.com/atom?hl=pl&gl=PL&ceid=PL:pl,https://pl.euronews.com/rss?format=mrss,https://antyweb.pl/feed/,https://raw.githubusercontent.com/trvny/feeds/main/feedseek/feeds/feed_wikipedia_pl.xml,https://raw.githubusercontent.com/trvny/feeds/main/feedseek/feeds/feed_daily_digest.xml,https://raw.githubusercontent.com/trvny/feeds/main/feedseek/feeds/feed_jbzd.xml",
    "ALLOWED_HOSTS": ""
  },

  // Durable cross-colo cache for /discover and /scrape so a cold edge cache
  // doesn't re-hit origin sites. The Worker also runs fine without it (Cache API
  // only) — writes are gated to cache-miss + TTL'd, well inside the KV free tier
  // (100k reads/day, 1k writes/day). Forking this repo? Swap in your own id:
  //   npx wrangler kv namespace create kanarek-scrape
  "kv_namespaces": [
    { "binding": "SCRAPE_KV", "id": "1534e989ac23449fab8e18abc2bc250d" }
  ],

  // Per-device read-state, subscriptions, and pairing. Write-heavy (every
  // mark-read), so it lives in D1, not KV: D1 free tier is 100k rows written/day
  // vs KV's shared 1k writes/day. Absent binding => /state and /pair return 503;
  // the rest of the Worker is unaffected. Create + wire the id with:
  //   npx wrangler d1 create feedget-state
  //   npx wrangler d1 migrations apply feedget-state --remote
  "d1_databases": [
    { "binding": "STATE_DB", "database_name": "feedget-state", "database_id": "65695956-4148-4641-8a59-7b1756d4e312", "migrations_dir": "migrations" }
  ]
}
