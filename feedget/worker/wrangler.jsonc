{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fidy-news",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "observability": { "enabled": true },
  "vars": {
    "DEFAULT_FEEDS": "https://news.google.com/atom?hl=pl&gl=PL&ceid=PL:pl,https://pl.euronews.com/rss?format=mrss,https://antyweb.pl/feed/",
    "ALLOWED_HOSTS": ""
  }
}
